<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.hello.mapper.EmpExprMapper">

    <resultMap id="EmpExprResultMap" type="com.example.hello.entity.EmpExpr">
        <id column="id" property="id"/>
        <result column="emp_id" property="empId"/>
        <result column="company" property="company"/>
        <result column="position" property="position"/>
        <result column="start_date" property="startDate"/>
        <result column="end_date" property="endDate"/>
    </resultMap>

    <select id="findByEmpId" resultMap="EmpExprResultMap">
        SELECT id, emp_id, company, position, start_date, end_date
        FROM emp_expr
        WHERE emp_id = #{empId}
        ORDER BY start_date ASC
    </select>

    <insert id="insert" parameterType="com.example.hello.entity.EmpExpr" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO emp_expr (emp_id, company, position, start_date, end_date)
        VALUES (#{empId}, #{company}, #{position}, #{startDate}, #{endDate})
    </insert>

    <update id="update" parameterType="com.example.hello.entity.EmpExpr">
        UPDATE emp_expr
        SET company = #{company},
            position = #{position},
            start_date = #{startDate},
            end_date = #{endDate}
        WHERE id = #{id} AND emp_id = #{empId}
    </update>

    <delete id="deleteByEmpId">
        DELETE FROM emp_expr WHERE emp_id = #{empId}
    </delete>

    <delete id="deleteByEmpIds">
        DELETE FROM emp_expr WHERE emp_id IN
        <foreach collection="empIds" item="empId" open="(" separator="," close=")">
            #{empId}
        </foreach>
    </delete>

    <delete id="deleteByEmpIdExcludeIds">
        DELETE FROM emp_expr
        WHERE emp_id = #{empId}
        <if test="ids != null and ids.size() > 0">
            AND id NOT IN
            <foreach collection="ids" item="id" open="(" separator="," close=")">
                #{id}
            </foreach>
        </if>
    </delete>

</mapper>
