<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.hello.mapper.EmpMapper">

    <resultMap id="EmpResultMap" type="com.example.hello.entity.Emp">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="name" property="name"/>
        <result column="gender" property="gender"/>
        <result column="phone" property="phone"/>
        <result column="job" property="position"/>
        <result column="salary" property="salary"/>
        <result column="image" property="image"/>
        <result column="entry_date" property="hireDate"/>
        <result column="dept_id" property="deptId"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="dept_name" property="deptName"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, username, password, name, gender, phone, salary, image,
        entry_date, dept_id, create_time, update_time
    </sql>

    <select id="list" resultMap="EmpResultMap">
        SELECT e.id, e.username, e.name, e.gender, e.image, e.salary,
               e.entry_date, e.dept_id, d.name AS dept_name, e.create_time, e.update_time
        FROM emp e
        LEFT JOIN dept d ON e.dept_id = d.id
        <where>
            <if test="name != null and name != ''">
                AND e.name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="gender != null">
                AND e.gender = #{gender}
            </if>
            <if test="begin != null">
                AND e.entry_date &gt;= #{begin}
            </if>
            <if test="end != null">
                AND e.entry_date &lt;= #{end}
            </if>
        </where>
        ORDER BY e.update_time DESC
    </select>

    <select id="findById" resultMap="EmpResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM emp
        WHERE id = #{id}
    </select>

    <select id="findByUsername" resultMap="EmpResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM emp
        WHERE username = #{username}
    </select>

    <select id="findAll" resultMap="EmpResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM emp
        ORDER BY id ASC
    </select>

    <insert id="insert" parameterType="com.example.hello.entity.Emp" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO emp (username, password, name, gender, phone, salary, image, entry_date, dept_id, create_time, update_time)
        VALUES (#{username}, #{password}, #{name}, #{gender}, #{phone}, #{salary}, #{image}, #{hireDate}, #{deptId}, #{createTime}, #{updateTime})
    </insert>

    <update id="update" parameterType="com.example.hello.entity.Emp">
        UPDATE emp
        <set>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="username != null">username = #{username},</if>
            <if test="password != null">password = #{password},</if>
            <if test="name != null">name = #{name},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="salary != null">salary = #{salary},</if>
            <if test="image != null">image = #{image},</if>
            <if test="hireDate != null">entry_date = #{hireDate},</if>
            <if test="deptId != null">dept_id = #{deptId},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteByIds">
        DELETE FROM emp WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
